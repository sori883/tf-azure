# このファイルを terraform.tfvars にコピーして値を設定してください。
# terraform.tfvars は .gitignore 済みのためコミットされません。
#
#   cp terraform.tfvars.example terraform.tfvars

subscription_id = "00000000-0000-0000-0000-000000000000"
location        = "japaneast"
environment     = "dev"

# リソース名の接頭辞。AOAI アカウント名と APIM 名はグローバルに一意である必要があるため、
# 他と衝突しない値にすること（例: 会社名やイニシャル + 乱数）。
name_prefix = "myorg-gpt-dev"

# Azure OpenAI / モデルデプロイ
aoai_deployment_name = "gpt-5.4-pro"
aoai_model_name      = "gpt-5.4-pro"
# aoai_model_version = "2025-xx-xx"   # 必要なら対象リージョンで利用可能なバージョンを指定
aoai_deployment_sku_name = "GlobalStandard"
aoai_deployment_capacity = 1

# ネットワーク（APIM を VNet injection、AOAI を Private Endpoint 化）
vnet_address_space = ["10.0.0.0/16"]
apim_subnet_prefix = ["10.0.1.0/24"]
pe_subnet_prefix   = ["10.0.2.0/24"]

# API Management（Developer SKU 維持。External VNet injection でゲートウェイは public のまま）
apim_sku_name        = "Developer_1"
apim_publisher_name  = "myorg"
apim_publisher_email = "admin@example.com"

tags = {
  managed_by = "terraform"
  project    = "tf-azure"
}
